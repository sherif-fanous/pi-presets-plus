{
  "name": "@sherif-fanous/pi-presets-plus",
  "version": "0.1.4",
  "description": "Pi extension: model + thinking + tools + system-prompt presets, with a UI on top.",
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "presets",
    "favorites",
    "model-presets",
    "thinking-presets",
    "tools-presets",
    "system-prompt-presets"
  ],
  "license": "MIT",
  "author": "Sherif Fanous",
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "format": "prettier --write eslint.config.mjs package.json src/. tests/. tsconfig.json vitest.config.ts",
    "format-check": "prettier --check eslint.config.mjs package.json src/. tests/. tsconfig.json vitest.config.ts",
    "lint": "biome lint src/. tests/. && eslint src/. tests/.",
    "sort-package-json": "npx sort-package-json",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "prettier": {
    "importOrder": [
      "<BUILTIN_MODULES>",
      "",
      "<THIRD_PARTY_MODULES>"
    ],
    "importOrderTypeScriptVersion": "6.0.0",
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mariozechner/pi-ai": "^0.73.0",
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "@mariozechner/pi-tui": "^0.73.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "fallow": "^2.55.0",
    "prettier": "^3.8.3",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
